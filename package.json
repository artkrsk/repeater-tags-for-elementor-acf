{
  "name": "repeater-tags-for-elementor-acf",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.17.0"
  },
  "scripts": {
    "dev": "pnpm sync:fixtures && node build/index.js dev",
    "build": "node build/index.js build",
    "sync": "pnpm sync:fixtures",
    "sync:fixtures": "node dev/sync-fixtures.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "phpstan": "composer phpstan",
    "test": "pnpm build && wp-env start && pnpm test:php && pnpm test:php:no-provider",
    "test:php": "wp-env run tests-cli --env-cwd=test-workspace -- vendor/bin/phpunit",
    "test:php:no-provider": "wp-env run tests-cli --env-cwd=test-workspace -- vendor/bin/phpunit -c phpunit-no-provider.xml.dist"
  },
  "devDependencies": {
    "@artemsemkin/elementor-types": "^1.0.10",
    "@wordpress/env": "11.10.0",
    "@biomejs/biome": "2.5.3",
    "@types/node": "^26.1.1",
    "archiver": "^8.0.0",
    "chokidar": "^5.0.0",
    "esbuild": "0.28.1",
    "sass": "^1.101.0",
    "typescript": "^7.0.2"
  }
}
